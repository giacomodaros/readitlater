{
  "manifest_version": 3,
  "name": "Reader by Artifacts",
  "description": "Save any article to your Reader with one click.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Reader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://readlater-pi.vercel.app/*"]
}
