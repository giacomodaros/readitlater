{
  "manifest_version": 3,
  "name": "Save Article",
  "description": "Save any article to your private library.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save article",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "cookies"],
  "host_permissions": ["https://readitlater-theta.vercel.app/*"]
}
